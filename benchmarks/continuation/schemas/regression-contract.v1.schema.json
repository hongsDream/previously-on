{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "regression-contract.v1.schema.json",
  "title": "PreviouslyOn Regression Contract V1 benchmark fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "invariant",
    "status",
    "supersededBy",
    "impactSelectors",
    "requiredTests",
    "origin"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "title": { "type": "string", "minLength": 1 },
    "invariant": { "type": "string", "minLength": 1 },
    "status": { "enum": ["active", "superseded"] },
    "supersededBy": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "impactSelectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "symbols"],
        "properties": {
          "path": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "value"],
            "properties": {
              "kind": { "enum": ["exact", "prefix"] },
              "value": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
              }
            }
          },
          "symbols": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[^\\s\\u0000]+$"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "requiredTests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "program",
          "args",
          "workingDirectory",
          "timeoutSeconds"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "program": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000]+$"
          },
          "args": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[^\\u0000]*$" }
          },
          "workingDirectory": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
          },
          "timeoutSeconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3600
          }
        }
      }
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixedAtCommit", "recordedAt", "evidenceSha256"],
      "properties": {
        "fixedAtCommit": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{40}$"
        },
        "recordedAt": { "type": "string", "format": "date-time" },
        "evidenceSha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        }
      }
    }
  }
}
